{
  "id": "nextclaw-ncp-runtime-plugin-codex-sdk",
  "kind": "agent-runtime",
  "name": "NextClaw Codex NCP Runtime",
  "description": "Registers NCP session type `codex` backed by OpenAI Codex SDK.",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "apiKey": {
        "type": "string"
      },
      "apiBase": {
        "type": "string"
      },
      "model": {
        "type": "string"
      },
      "supportedModels": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "modelProvider": {
        "type": "string"
      },
      "workingDirectory": {
        "type": "string"
      },
      "accessMode": {
        "type": "string",
        "enum": ["read-only", "workspace-write", "full-access"],
        "default": "full-access"
      },
      "skipGitRepoCheck": {
        "type": "boolean"
      },
      "networkAccessEnabled": {
        "type": "boolean"
      },
      "webSearchMode": {
        "type": "string",
        "enum": ["disabled", "cached", "live"]
      },
      "webSearchEnabled": {
        "type": "boolean"
      },
      "codexPathOverride": {
        "type": "string"
      },
      "additionalDirectories": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "env": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      },
      "config": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "uiHints": {
    "apiKey": {
      "label": "Codex API Key",
      "help": "Optional. Falls back to the selected provider API key when omitted.",
      "sensitive": true
    },
    "apiBase": {
      "label": "Codex API Base"
    },
    "model": {
      "label": "Default Model"
    },
    "supportedModels": {
      "label": "Supported Models",
      "help": "Optional advanced allowlist. Leave empty for no model restriction. Use [\"*\"] to explicitly allow any model.",
      "advanced": true
    },
    "modelProvider": {
      "label": "External Model Provider",
      "help": "Optional override for the provider id exposed to Codex SDK. Recommended for custom providers whose display name is not the actual upstream provider id.",
      "advanced": true
    },
    "workingDirectory": {
      "label": "Working Directory",
      "advanced": true
    },
    "accessMode": {
      "label": "Access Mode",
      "help": "Product-facing permission model. Defaults to full-access; internally this is mapped to the Codex SDK sandbox/approval settings.",
      "advanced": true
    },
    "networkAccessEnabled": {
      "label": "Enable Network",
      "advanced": true
    },
    "webSearchEnabled": {
      "label": "Enable Web Search",
      "advanced": true
    }
  }
}
